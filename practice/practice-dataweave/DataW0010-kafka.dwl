------------------------------------------------------------------------------------
%dw 2.0
output application/json

var allowedKeys = ["key", "creationTimestamp", "partition", "offset"]

---
payload map (item) -> {
    // Filter attributes to only allowed keys
    attributes: item.attributes filterObject ((value, key) -> allowedKeys contains (key as String)),

    // Directly reference filtered attributes
    messageKey: item.attributes.key,
    messagePublishedTS: item.attributes.creationTimestamp,
    topicPartition: item.attributes.partition,
    topicPartitionOffset: item.attributes.offset
}

Single map: Removed the redundant payload.attributes map and nested do{} block.
Reusable list: Defined allowedKeys once for clarity and easy maintenance.
Inline filterObject: No need for a separate var attrObj; filter directly.
Cleaner structure: Each output field is directly tied to the filtered attributes.

payload:
{
  "attributes": {
    "key": "abc123",
    "creationTimestamp": "2026-04-26T23:00:00Z",
    "partition": 2,
    "offset": 45,
    "extraField": "ignoreMe"
  }
}
-----------------------------------------------------------------------------------
%dw 2.0
output application/json

var allowedKeys = ["key", "creationTimestamp", "partition", "offset"]

---
(payloadDeserialized map $.payload) zip (
    payload.attributes map (item) ->
        item filterObject ((value, key) -> allowedKeys contains (key as String))
)
map ((valuePart, attrPart) -> {
    attributes: attrPart,
    value: flatten(valuePart)[0] ++ {
        messageKey: attrPart.key,
        messagePublishedTS: attrPart.creationTimestamp,
        topicPartition: attrPart.partition,
        topicPartitionOffset: attrPart.offset
    }
})


payload:
{
  "payloadDeserialized": [
    { "payload": [ { "field1": "A" } ] },
    { "payload": [ { "field1": "B" } ] }
  ],
  "payload": {
    "attributes": [
      {
        "key": "abc123",
        "creationTimestamp": "2026-04-26T23:00:00Z",
        "partition": 2,
        "offset": 45,
        "extraField": "ignoreMe"
      },
      {
        "key": "xyz789",
        "creationTimestamp": "2026-04-26T23:05:00Z",
        "partition": 3,
        "offset": 99
      }
    ]
  }
}
